// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  RADIOLOGIST
  CLINICIAN
  TECH
  ADMIN
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          UserRole  @default(CLINICIAN)
  accounts      Account[]
  sessions      Session[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum AppointmentStatus {
  SCHEDULED
  ARRIVED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum OrderStatus {
  PENDING
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum StudyStatus {
  UNREPORTED
  DRAFT
  FINALIZED
  ARCHIVED
}

model Patient {
  id           String        @id @default(cuid())
  patientId    String        @unique // Hospital/MRN
  firstName    String
  lastName     String
  dob          DateTime
  gender       String
  email        String?
  phone        String?
  address      String?
  appointments Appointment[]
  orders       Order[]
  studies      Study[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Appointment {
  id        String            @id @default(cuid())
  patientId String
  patient   Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  start     DateTime
  end       DateTime
  status    AppointmentStatus @default(SCHEDULED)
  reason    String?
  notes     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Order {
  id              String      @id @default(cuid())
  patientId       String
  patient         Patient     @relation(fields: [patientId], references: [id], onDelete: Cascade)
  accessionNumber String?     @unique
  modality        String
  description     String?
  status          OrderStatus @default(PENDING)
  priority        String      @default("ROUTINE") // ROUTINE, STAT, URGENT

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Study {
  id               String      @id @default(cuid())
  studyInstanceUid String      @unique
  patientId        String
  patient          Patient     @relation(fields: [patientId], references: [id], onDelete: Cascade)
  accessionNumber  String?
  modality         String
  description      String?
  studyDate        DateTime
  orthancId        String?     @unique
  status           StudyStatus @default(UNREPORTED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
